{
  "name": "@rnaga/wp-next-editor",
  "version": "0.1.32",
  "license": "MIT",
  "description": "Editor interface for WP Next",
  "author": "Ryohei Nagatsuka",
  "keywords": [
    "wordpress",
    "webbuilder",
    "editor",
    "cms",
    "nextjs"
  ],
  "scripts": {
    "dev": "next dev --webpack",
    "build:dev": "NEXT_BUILD_DEV=true next build --webpack",
    "build:dev-turbopack": "NEXT_BUILD_DEV=true next build --turbo",
    "build": "node ../../scripts/build-editor.mjs",
    "start": "next start",
    "lint": "next lint",
    "release": "../../scripts/release-gh.sh",
    "google-fonts:local": "node --env-file=.env.local --experimental-strip-types google-fonts.ts"
  },
  "dependencies": {
    "@lexical/html": "^0.40",
    "@lexical/react": "^0.40",
    "@monaco-editor/react": "next",
    "@mui/material": "^9",
    "@mui/x-tree-view": "^9",
    "@preact/signals-react": "^2.3.0",
    "@rnaga/wp-next-admin": "^1",
    "@rnaga/wp-next-core": "^1",
    "@rnaga/wp-next-rte": "^1",
    "@rnaga/wp-next-ui": "^1",
    "@rnaga/wp-node": ">=1",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^171.4.0",
    "jsdom": "^25.0.0",
    "lexical": "^0.40",
    "next": "^16.1",
    "react": "^19",
    "react-dom": "^19",
    "terser": "^5.44.1"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10",
    "typescript": "^5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rnaga/wp-next.git"
  }
}
